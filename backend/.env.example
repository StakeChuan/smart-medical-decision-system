# MySQL 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的MySQL密码
DB_NAME=smart_medical_system

# 认证配置
# 本机开发可使用 development；公网或正式部署必须改为 production。
ENVIRONMENT=development
# production 环境必须填写至少 32 个字符的随机值，不能使用演示密钥。
APP_TOKEN_SECRET=
TOKEN_EXPIRE_SECONDS=43200

# 阿里云百炼 / DashScope 配置
# DASHSCOPE_API_KEY 必填，真实 Key 请只写入 backend/.env，不要提交到 GitHub。
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_TIMEOUT=60

# Medical Agent / 本地医学知识库
MEDICAL_AGENT_ENGINE=langgraph
MEDICAL_RAG_ENABLED=false
MEDICAL_RAG_TOP_K=4
MEDICAL_RAG_MIN_SCORE=0.72
MEDICAL_RAG_MAX_CONTEXT_CHARS=6000
# 使用绝对路径；RAG 开启时必填。索引更新后需重启后端。
MEDICAL_KNOWLEDGE_INDEX_PATH=
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSIONS=1024
