# MySQL 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的MySQL密码
DB_NAME=smart_medical_system

# 登录 token 配置
# 正式部署时建议把 APP_TOKEN_SECRET 改成更复杂的随机字符串。
APP_TOKEN_SECRET=smart-medical-demo-secret
APP_TOKEN_EXPIRE_SECONDS=43200

# 阿里云百炼 / DashScope 配置
# DASHSCOPE_API_KEY 必填，真实 Key 请只写入 backend/.env，不要提交到 GitHub。
DASHSCOPE_API_KEY=你的阿里云百炼APIKey
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_TIMEOUT=60
